@page "/events"
@attribute [Authorize]
@inject ISchoolService SchoolService

<div class="page-title">
    <div>
        <h2>Events</h2>
        <p class="text-muted">Upcoming academic and campus events.</p>
    </div>
</div>

<div class="data-card">
    @if (events.Count == 0)
    {
        <div class="empty-state">No events available.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Event</th>
                        <th>Location</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in events)
                    {
                        <tr>
                            <td>@item.EventDate.ToString("dd MMM yyyy")</td>
                            <td>@item.Title</td>
                            <td>@item.Location</td>
                            <td>@item.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<CalendarEvent> events = new();

    protected override async Task OnInitializedAsync()
    {
        events = (await SchoolService.GetEventsAsync())
            .OrderBy(item => item.EventDate)
            .ToList();
    }
}
