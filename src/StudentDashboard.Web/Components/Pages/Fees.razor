@page "/fees"
@attribute [Authorize]
@inject ISchoolService SchoolService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-title">
    <div>
        <h2>My Fees</h2>
        <p class="text-muted">View your fee invoices and simulate payment for pending dues.</p>
    </div>
</div>

<AlertBox Message="@message" Type="@messageType" />

<div class="grid grid-3 mb-3">
    <StatCard Title="Total Invoices" Value="@invoices.Count.ToString()" Description="Fee records" Icon="🧾" />
    <StatCard Title="Pending Amount" Value="@($"PKR {pendingAmount:N0}")" Description="Unpaid dues" Icon="💳" AccentClass="warning" />
    <StatCard Title="Paid Invoices" Value="@paidCount.ToString()" Description="Completed payments" Icon="✅" AccentClass="success" />
</div>

<div class="data-card">
    @if (invoices.Count == 0)
    {
        <div class="empty-state">No fee records available.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Amount</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Notes</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in invoices)
                    {
                        <tr>
                            <td>PKR @item.Amount.ToString("N0")</td>
                            <td>@item.DueDate.ToString("dd MMM yyyy")</td>
                            <td><span class="@(item.IsPaid ? "status-pill success" : "status-pill warning")">@(item.IsPaid ? "Paid" : "Pending")</span></td>
                            <td>@item.Notes</td>
                            <td>
                                @if (!item.IsPaid)
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => PayFeeAsync(item.Id)">Pay Now</button>
                                }
                                else
                                {
                                    <span class="text-muted">Completed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

