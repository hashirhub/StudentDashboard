@page "/grades"
@attribute [Authorize]
@inject ISchoolService SchoolService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-title">
    <div>
        <h2>My Grades</h2>
        <p class="text-muted">View your personal grade records and performance.</p>
    </div>
</div>

<div class="grid grid-3 mb-3">
    <StatCard Title="Assessments" Value="@grades.Count.ToString()" Description="Grade records" Icon="📝" />
    <StatCard Title="Average" Value="@($"{averageGrade}%")" Description="Overall percentage" Icon="📊" AccentClass="success" />
    <StatCard Title="Best Score" Value="@($"{bestGrade}%")" Description="Highest percentage" Icon="🏆" AccentClass="warning" />
</div>

<div class="data-card">
    @if (grades.Count == 0)
    {
        <div class="empty-state">No grade records available.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Assessment</th>
                        <th>Marks</th>
                        <th>Total</th>
                        <th>Percentage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in grades)
                    {
                        <tr>
                            <td>@item.Course?.Code - @item.Course?.Title</td>
                            <td>@item.ExamType</td>
                            <td>@item.MarksObtained</td>
                            <td>@item.TotalMarks</td>
                            <td><span class="status-pill success">@item.Percentage%</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<GradeRecord> grades = new();
    private decimal averageGrade;
    private decimal bestGrade;

    protected override async Task OnInitializedAsync()
    {
        var student = await GetCurrentStudentAsync();
        if (student is null)
        {
            return;
        }

        grades = (await SchoolService.GetGradesAsync())
            .Where(item => item.StudentId == student.Id)
            .ToList();

        averageGrade = grades.Count == 0 ? 0 : Math.Round(grades.Average(item => item.Percentage), 2);
        bestGrade = grades.Count == 0 ? 0 : grades.Max(item => item.Percentage);
    }

    private async Task<Student?> GetCurrentStudentAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = state.User.Identity?.Name ?? "irtaza@studentdash.local";
        var students = await SchoolService.GetStudentsAsync(email);
        return students.FirstOrDefault(item => item.Email.Equals(email, StringComparison.OrdinalIgnoreCase))
            ?? students.FirstOrDefault()
            ?? (await SchoolService.GetStudentsAsync()).FirstOrDefault();
    }
}
