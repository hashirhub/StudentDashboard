@page "/assignments"
@attribute [Authorize]
@inject ISchoolService SchoolService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-title">
    <div>
        <h2>Assignments</h2>
        <p class="text-muted">Assignments from your enrolled courses.</p>
    </div>
</div>

<div class="data-card">
    @if (assignments.Count == 0)
    {
        <div class="empty-state">No assignments available for your courses.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Due Date</th>
                        <th>Marks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in assignments)
                    {
                        <tr>
                            <td>@item.Course?.Code</td>
                            <td>@item.Title</td>
                            <td>@item.Description</td>
                            <td>@item.DueDate.ToString("dd MMM yyyy")</td>
                            <td>@item.TotalMarks</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
