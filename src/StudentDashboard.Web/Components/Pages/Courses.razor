@page "/courses"
@attribute [Authorize]
@inject ISchoolService SchoolService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-title">
    <div>
        <h2>My Courses</h2>
        <p class="text-muted">Courses currently assigned to your student account.</p>
    </div>
</div>

<div class="data-card">
    <div class="toolbar mb-3">
        <InputText class="form-control" placeholder="Search my courses" @bind-Value="searchTerm" />
        <button class="btn btn-primary" @onclick="LoadCoursesAsync">Search</button>
    </div>

    @if (enrollments.Count == 0)
    {
        <div class="empty-state">No enrolled courses found.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Course Code</th>
                        <th>Course Title</th>
                        <th>Instructor</th>
                        <th>Credits</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
