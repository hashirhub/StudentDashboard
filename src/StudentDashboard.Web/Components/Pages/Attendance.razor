@page "/attendance"
@attribute [Authorize]
@inject ISchoolService SchoolService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-title">
    <div>
        <h2>My Attendance</h2>
        <p class="text-muted">View your personal attendance records and percentage.</p>
    </div>
</div>

<div class="grid grid-3 mb-3">
    <StatCard Title="Total Classes" Value="@records.Count.ToString()" Description="Attendance records" Icon="📅" />
    <StatCard Title="Present" Value="@presentCount.ToString()" Description="Classes attended" Icon="✅" AccentClass="success" />
    <StatCard Title="Attendance %" Value="@($"{attendancePercentage}%")" Description="Your attendance ratio" Icon="📊" AccentClass="warning" />
</div>

<div class="data-card">
    @if (records.Count == 0)
    {
        <div class="empty-state">No attendance records available.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Course</th>
                        <th>Status</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in records)
                    {
                        <tr>
                            <td>@item.AttendanceDate.ToString("dd MMM yyyy")</td>
                            <td>@item.Course?.Code - @item.Course?.Title</td>
                            <td><span class="@GetStatusClass(item.Status)">@item.Status</span></td>
                            <td>@item.Remarks</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<AttendanceRecord> records = new();
    private int presentCount;
    private decimal attendancePercentage;

