@page "/attendance"
@attribute [Authorize]
@inject ISchoolService SchoolService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-title">
    <div>
        <h2>My Attendance</h2>
        <p class="text-muted">View your personal attendance records and percentage.</p>
    </div>
</div>

<div class="grid grid-3 mb-3">
    <StatCard Title="Total Classes" Value="@records.Count.ToString()" Description="Attendance records" Icon="📅" />
    <StatCard Title="Present" Value="@presentCount.ToString()" Description="Classes attended" Icon="✅" AccentClass="success" />
    <StatCard Title="Attendance %" Value="@($"{attendancePercentage}%")" Description="Your attendance ratio" Icon="📊" AccentClass="warning" />
</div>

<div class="data-card">
    @if (records.Count == 0)
    {
        <div class="empty-state">No attendance records available.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Course</th>
                        <th>Status</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in records)
                    {
                        <tr>
                            <td>@item.AttendanceDate.ToString("dd MMM yyyy")</td>
                            <td>@item.Course?.Code - @item.Course?.Title</td>
                            <td><span class="@GetStatusClass(item.Status)">@item.Status</span></td>
                            <td>@item.Remarks</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<AttendanceRecord> records = new();
    private int presentCount;
    private decimal attendancePercentage;

    protected override async Task OnInitializedAsync()
    {
        var student = await GetCurrentStudentAsync();
        if (student is null)
        {
            return;
        }

        records = (await SchoolService.GetAttendanceAsync())
            .Where(item => item.StudentId == student.Id)
            .OrderByDescending(item => item.AttendanceDate)
            .ToList();

        presentCount = records.Count(item => item.Status == "Present");
        attendancePercentage = records.Count == 0 ? 0 : Math.Round((decimal)presentCount / records.Count * 100, 2);
    }

    private static string GetStatusClass(string status)
    {
        return status == "Present" ? "status-pill success" : "status-pill danger";
    }

    private async Task<Student?> GetCurrentStudentAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = state.User.Identity?.Name ?? "irtaza@studentdash.local";
        var students = await SchoolService.GetStudentsAsync(email);
        return students.FirstOrDefault(item => item.Email.Equals(email, StringComparison.OrdinalIgnoreCase))
            ?? students.FirstOrDefault()
            ?? (await SchoolService.GetStudentsAsync()).FirstOrDefault();
    }
}
