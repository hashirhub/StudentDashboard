@inject DashboardAuthStateProvider AuthProvider
@inject NavigationManager Navigation

<aside class="sidebar">
    <div class="brand">
        <div class="brand-icon">🎓</div>
        <div>
            <strong>Student Dashboard</strong>
            <small>Student account</small>
        </div>
    </div>
 <AuthorizeView Context="authState">
        <Authorized>
            <div class="sidebar-user simple-user">
                <div class="avatar-badge">@GetInitials(authState.User.Identity?.Name)</div>
                <div>
                    <strong>@GetStudentName(authState.User.Identity?.Name)</strong>
                    <small>Student account</small>
                </div>
            </div>
